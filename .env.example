# Entorno
NODE_ENV=development

# Servidor
PORT=3000
HTTP_REQUEST_LOGGER_ENABLED=true
HTTP_REQUEST_LOGGER_MAX_BODY_LENGTH=2000

# PostgreSQL (local)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=sistema_sarita
DB_SSL=false

# Neon / producción (recomendado: URL del pooler)
# DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&uselibpqcompat=true
# DB_SSL=true

# Pool (opcional)
# DB_POOL_MAX=10
# DB_IDLE_TIMEOUT_MS=30000
# DB_CONNECTION_TIMEOUT_MS=10000

# JWT
JWT_SECRET=cambia_este_secreto_en_produccion_min_16
JWT_EXPIRES_IN=24h

# APIsPERU — consultas (DNI / RUC)
# APIS_PERU_TOKEN=tu_token_consultas

# APIsPERU — facturación electrónica (swagger: facturacion.apisperu.com)
FACTURACION_APISPERU_ENABLED=true
FACTURACION_APISPERU_BASE_URL=https://facturacion.apisperu.com/api/v1
# Token de empresa (recomendado, no caduca) — o usar USERNAME/PASSWORD para login
FACTURACION_APISPERU_TOKEN=
FACTURACION_APISPERU_USERNAME=
FACTURACION_APISPERU_PASSWORD=
# RUC emisor por defecto (consultas multi-empresa)
FACTURACION_APISPERU_RUC=
# OAuth CPE GRE (portal SUNAT) — obligatorio para POST /despatch/send
FACTURACION_APISPERU_CLIENT_ID=
FACTURACION_APISPERU_CLIENT_SECRET=
FACTURACION_APISPERU_TIMEOUT_MS=60000
